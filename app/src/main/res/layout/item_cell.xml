<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_margin="6dp" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:cardBackgroundColor="@color/card" android:cardCornerRadius="6dp" android:padding="10dp">

    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
        <View android:id="@+id/connectedDot" android:layout_width="10dp" android:layout_height="10dp" android:layout_marginEnd="8dp" android:background="@color/green_light" android:visibility="gone"/>
        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
            <TextView android:id="@+id/tvCellType" android:textColor="@color/text" android:text="LTE" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvCellInfo" android:textColor="@color/text" android:text="CID / PCI / -95 dBm / B3" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView android:id="@+id/tvSignalShort" android:textColor="@color/text" android:text="-95 dBm" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>